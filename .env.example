# PostgreSQL 核心配置
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=papers_records

# 对象存储
S3_ENDPOINT=https://cos.ap-beijing.myqcloud.com
S3_ACCESS_KEY=your_secret_id
S3_SECRET_KEY=your_secret_key
S3_BUCKET_NAME=tcm-documents-1387425381
S3_REGION=ap-beijing

# pdf上传设置

UPLOAD_MAX_FILE_SIZE_MB=10
UPLOAD_ALLOWED_EXTENSIONS=.pdf

# Graph builder settings
GRAPH_BUILDER_STRATEGY=truncate
GRAPH_BUILDER_PAPER_TOP_K=3
GRAPH_BUILDER_RECORD_TOP_K=2
GRAPH_BUILDER_PAPER_MIN_SCORE=0.02
GRAPH_BUILDER_RECORD_MIN_SCORE=0.02

# Gemini API Configuration
RELAY_BASE_URL=https://x666.me/v1beta/models/{model}:streamGenerateContent?alt=sse
RELAY_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

RAGFLOW_MYSQL_USER=rag_flow
RAGFLOW_MYSQL_PASSWORD=T
RAGFLOW_MYSQL_DB=rag_flow
RAGFLOW_REDIS_PASSWORD=
RAGFLOW_S3_BUCKET=ragflow-bucket
RAGFLOW_ES_PASSWORD=

# RAGFlow sync configuration
RAGFLOW_BASE_URL=http://127.0.0.1:9380
RAGFLOW_API_KEY=
RAGFLOW_DATASET_ID=
RAGFLOW_PARSE_AFTER_UPLOAD=true
RAGFLOW_REQUEST_TIMEOUT=120
RAGFLOW_DOMAIN=DOR infertility

# agent LLM配置
LLM_MODEL=
LLM_BASE_URL=
LLM_API_KEY=
